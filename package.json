{
  "name": "ipmc",
  "version": "1.0.0",
  "description": "Imperial Coin Identifier - IPMC Desktop Application",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\" \"wait-on http://localhost:3001 && electron .\"",
    "backend": "node backend/server.js",
    "frontend": "cd frontend && npm start",
    "electron": "electron .",
    "build": "cd frontend && npm run build && cd .. && electron-builder",
    "import-csv": "node scripts/import-csv.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "multer": "^1.4.5-lts.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ipmc.coinidentifier",
    "productName": "IPMC - Imperial Coin Identifier",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/build/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "backend/db",
        "to": "db"
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
